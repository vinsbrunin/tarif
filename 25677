// ─ FILTER MATCH ─
function matchWine(w){
  if(search){
    const hay=[w.nom,w.domaine,w.appellation,w.region,w.couleur,w.millesime,w.cepages,w.description,w.ref].join(' ').toLowerCase();
    if(!search.trim().split(/\s+/).every(t=>hay.includes(t.toLowerCase())))return false;
  }
  if(F.region&&w.region!==F.region)return false;
  if(F.domaine&&w.domaine!==F.domaine)return false;
  if(F.couleur){
    if(F.couleur==='Bulles'){const c=w.couleur.toLowerCase();if(!c.includes('bulle')&&!['CHAMPAGNE','CREMANT','CAVA','BULLES','PROSECCO'].includes(w.region))return false;}
    else if(F.couleur==='Doux'){const c=w.couleur.toLowerCase();if(!c.includes('moelleux')&&!c.includes('liquor')&&!c.includes('vdn'))return false;}
    else if(w.couleur!==F.couleur)return false;
  }
  if(F.format){
    if(F.format==='BIG'){if(parseFloat(w.cl)<3)return false;}
    else if(w.cl!==F.format)return false;
  }
  if(F.millesime&&w.millesime!==F.millesime)return false;
  if(filterBio&&(!w.bio||w.bio==='nan'||!w.bio.trim()))return false;
  // Price range filter
  const p=getPrice(w);
  if(p!==null&&p!==undefined){
    if(p<priceRangeMin||p>priceRangeMax)return false;
  } else {
    // No price: show only if range is at full extent
    if(priceRangeMin>0||priceRangeMax<9999)return false;
  }
  return true;
}

