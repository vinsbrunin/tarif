function render(){
  if(currentTab==='spirits'){renderSpirits();return;}
  let list=WINES.filter(matchWine);
  const RO=['BORDEAUX','BOURGOGNE','ALSACE','JURA','CHAMPAGNE','CREMANT','BULLES','VAL DE LOIRE','BEAUJOLAIS','SAVOIE','VALLEE DU RHONE NORD','VALLEE DU RHONE SUD','LANGUEDOC','ROUSSILLON','PROVENCE','SUD-OUEST','CORSE','ITALIE','PROSECCO','ESPAGNE','CAVA','PORTUGAL','ARMENIE','CHILI','ARGENTINE','AUTRICHE','GRECE','NOUVELLE ZELANDE','MAROC','LIBAN','BELGIQUE'];
  list.sort((a,b)=>{
    const ri=RO.indexOf(a.region),rj=RO.indexOf(b.region);
    if(ri!==rj)return(ri<0?99:ri)-(rj<0?99:rj);
    if(a.domaine!==b.domaine)return a.domaine.localeCompare(b.domaine,'fr');
    const pa=getPrice(a)||9999,pb=getPrice(b)||9999;return pa-pb;
  });
  document.getElementById('pill').textContent=list.length+' vin'+(list.length>1?'s':'');
  const el=document.getElementById('wl');el.innerHTML='';
  if(!list.length){el.innerHTML='<div class="empty"><div class="empty-i">🍷</div><p>Aucun vin trouvé.<br>Élargissez vos critères.</p></div>';return;}
  const gr={},or=[];
  list.forEach(w=>{if(!gr[w.region]){gr[w.region]=[];or.push(w.region);}gr[w.region].push(w);});
  or.forEach(region=>{
    const h=document.createElement('div');h.className='rh';
    h.innerHTML=`<h3>${RL[region]||region}</h3><div class="rl"></div><span class="rc">${gr[region].length}</span>`;
