      ${ti('Part. TTC',d.particulier_ttc,t==='particulier_ttc'&&isMkt)}
      ${ti('Horeca HTVA',d.horeca,t==='horeca'&&isMkt)}
      ${ti('Gros 1 HTVA',d.gros1,t==='gros1'&&isMkt)}
      ${ti('Gros 2 HTVA',d.gros2,t==='gros2'&&isMkt)}
    </div>`;}
  const hBel=bel&&Object.values(bel).some(v=>v!==null);
  const hFra=fra&&Object.values(fra).some(v=>v!==null);
  let html='';
  if(market==='belgique'&&hBel)html+=`<div class="ds"><div class="dh">🇧🇪 Belgique</div>${grid(bel,true)}</div>`;
  if(market==='france'&&hFra)html+=`<div class="ds"><div class="dh">🇫🇷 France</div>${grid(fra,true)}</div>`;
  html+=`<div class="wref">Réf. ${s.ref} · ${s.degre?s.degre+'°·':''} ${s.format||''}</div>`;
  return html;
}

let market='belgique', tarif='particulier_ttc';
let F={region:'',domaine:'',couleur:'',format:'',millesime:''};
let filterBio=false;
let search='', openRef=null;
let priceRangeMin=0, priceRangeMax=9999;
let selection=new Map(); // ref -> wine object

const TL={particulier_htva:'Part. HTVA',particulier_ttc:'Part. TTC',horeca:'Horeca HTVA',gros1:'Gros 1 HTVA',gros2:'Gros 2 HTVA'};
const RL={BORDEAUX:'Bordeaux',ALSACE:'Alsace',BOURGOGNE:'Bourgogne','VAL DE LOIRE':'Val de Loire','VALLEE DU RHONE SUD':'Vallée du Rhône',LANGUEDOC:'Languedoc',ROUSSILLON:'Roussillon',PROVENCE:'Provence','SUD-OUEST':'Sud-Ouest',CHAMPAGNE:'Champagne',CREMANT:'Crémant',BULLES:'Bulles',CAVA:'Cava',ITALIE:'Italie',ESPAGNE:'Espagne',PORTUGAL:'Portugal',ARMENIE:'Arménie',CHILI:'Chili',ARGENTINE:'Argentine',AUTRICHE:'Autriche',GRECE:'Grèce','NOUVELLE ZELANDE':'Nouvelle-Zélande',MAROC:'Maroc',LIBAN:'Liban',PROSECCO:'Prosecco'};

function fmt(v){if(!v&&v!==0)return'—';return v.toFixed(2).replace('.',',')+' €'}
function fmtCL(cl){const v=parseFloat(cl);if(isNaN(v))return cl;return v>=1?v+'L':(v*100|0)+'cl'}
function getPrice(w){return w[market]?w[market][tarif]:null}

function colorCls(c){
  c=(c||'').toLowerCase();
  if(c.includes('rouge')||c.includes('claret'))return'rouge';
  if(c.includes('blanc')||c.includes('jaune')||c.includes('paille'))return'blanc';
  if(c.includes('rosé')||c.includes('rose'))return'rose';
  if(c.includes('bulle')||c.includes('crémant')||c.includes('cava')||c.includes('champagne')||c.includes('prosecco')||c.includes('saumur'))return'bulles';
  if(c.includes('moelleux')||c.includes('liquor')||c.includes('vdn'))return'doux';
  return'autre';
}

