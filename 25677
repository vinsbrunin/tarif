function setTab(tab){
  currentTab = tab;
  document.querySelectorAll('.tab').forEach(b=>b.classList.toggle('on', b.textContent.toLowerCase().includes(tab==='vins'?'vin':'spirit')));
  const isVins = tab==='vins';
  document.getElementById('filtersWines').style.display = isVins?'':'none';
  document.getElementById('filtersSpirits').style.display = isVins?'none':'';
  document.getElementById('priceWines').style.display = isVins?'':'none';
  document.getElementById('priceSpirits').style.display = isVins?'none':'';
  document.getElementById('pill').textContent = '— '+(isVins?'vins':'spirits');
  if(!isVins) initSpiritsFilters();
  render();
}

function initSpiritsFilters(){
  // Maisons
  const mr = document.getElementById('maisonsRow');
  mr.innerHTML = '<button class="ch on" data-sf="maison" data-sv="" onclick="setSFilter(\'maison\',\'\')">Toutes maisons</button>';
  Object.keys(SRD).forEach(m=>{
    const btn = document.createElement('button');
    btn.className='ch'; btn.dataset.sf='maison'; btn.dataset.sv=m;
    btn.onclick=()=>setSFilter('maison',m);
    btn.textContent=m.split(' ').map(w=>w[0]+w.slice(1).toLowerCase()).join(' ');
    mr.appendChild(btn);
  });
  updateCatFilter();
}

function updateCatFilter(){
  const cr = document.getElementById('catsRow');
  cr.innerHTML = '<button class="ch on" data-sf="categorie" data-sv="" onclick="setSFilter(\'categorie\',\'\')">Toutes catégories</button>';
  const cats = FS.maison ? (SRD[FS.maison]||[]) : [...new Set(SPIRITS.map(s=>s.categorie).filter(Boolean))];
  cats.forEach(c=>{
    if(!c) return;
    const btn = document.createElement('button');
    btn.className='ch'; btn.dataset.sf='categorie'; btn.dataset.sv=c;
    btn.onclick=()=>setSFilter('categorie',c);
    btn.textContent=c.split(' ').map(w=>w[0]+(w.slice(1).toLowerCase())).join(' ');
    cr.appendChild(btn);
  });
}

function setSFilter(type, val){
  FS[type]=val;
  if(type==='maison'){FS.categorie='';updateCatFilter();}
  document.querySelectorAll(`[data-sf="${type}"]`).forEach(b=>b.classList.toggle('on',b.dataset.sv===val));
  updSATags(); render();
}

function setSPriceRange(btn){
  document.querySelectorAll('#priceSpirits .prb').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  sPriceMin=parseFloat(btn.dataset.pmin);
  sPriceMax=parseFloat(btn.dataset.pmax);
  updSATags(); render();
}

function updSATags(){
  const el=document.getElementById('stagsRow'), tags=[];
  if(FS.maison) tags.push({l:FS.maison,t:'maison'});
  if(FS.categorie) tags.push({l:FS.categorie,t:'categorie'});
  if(sPriceMin>0||sPriceMax<9999){const btn=document.querySelector('#priceSpirits .prb.on');tags.push({l:btn?btn.textContent:'Budget',t:'sprice'});}
  el.classList.toggle('show',tags.length>0);
  el.innerHTML=tags.map(t=>`<span class="atag">${t.l}<button onclick="removeSFilter('${t.t}')">×</button></span>`).join('')+(tags.length>1?`<button class="rst-btn" onclick="resetSpirits()">Tout effacer</button>`:'');
}

function removeSFilter(type){
  if(type==='maison'){FS.maison='';FS.categorie='';document.querySelectorAll('[data-sf]').forEach(b=>b.classList.toggle('on',b.dataset.sv===''));updateCatFilter();}
  else if(type==='categorie'){FS.categorie='';document.querySelectorAll('[data-sf="categorie"]').forEach(b=>b.classList.toggle('on',b.dataset.sv===''));}
  else if(type==='sprice'){sPriceMin=0;sPriceMax=9999;document.querySelectorAll('#priceSpirits .prb').forEach((b,i)=>b.classList.toggle('on',i===0));}
  updSATags(); render();
}

function resetSpirits(){
  FS={maison:'',categorie:''};
  sPriceMin=0;sPriceMax=9999;
  document.querySelectorAll('[data-sf]').forEach(b=>b.classList.toggle('on',b.dataset.sv===''));
  document.querySelectorAll('#priceSpirits .prb').forEach((b,i)=>b.classList.toggle('on',i===0));
  updateCatFilter();
  updSATags(); render();
}

function matchSpirit(s){
  if(FS.maison && s.maison!==FS.maison) return false;
  if(FS.categorie && s.categorie!==FS.categorie) return false;
  const p = s[market]?s[market][tarif]:null;
  if(p!==null&&p!==undefined){if(p<sPriceMin||p>sPriceMax)return false;}
  else{if(sPriceMin>0||sPriceMax<9999)return false;}
  if(search){
    const hay=[s.nom,s.maison,s.categorie,s.format,s.degre,s.ref].join(' ').toLowerCase();
    if(!search.trim().split(/\s+/).every(t=>hay.includes(t.toLowerCase())))return false;
  }
  return true;
}

function renderSpirits(){
  const list=SPIRITS.filter(matchSpirit);
  list.sort((a,b)=>{
    if(a.maison!==b.maison)return a.maison.localeCompare(b.maison,'fr');
    if(a.categorie!==b.categorie)return a.categorie.localeCompare(b.categorie,'fr');
    const pa=getPrice(a)||9999, pb=getPrice(b)||9999; return pa-pb;
  });
  document.getElementById('pill').textContent=list.length+' spirit'+(list.length>1?'s':'');
  const el=document.getElementById('wl'); el.innerHTML='';
  if(!list.length){el.innerHTML='<div class="empty"><div class="empty-i">🥃</div><p>Aucun spiritueux trouvé.</p></div>';return;}
  const gd={},od=[];
  list.forEach(s=>{
    const k=s.maison+'|||'+s.categorie;
    if(!gd[k]){gd[k]=[];od.push(k);}
    gd[k].push(s);
  });
  let lastDomaine='';
  od.forEach(k=>{
    const [dom,cat]=k.split('|||');
    if(dom!==lastDomaine){
      lastDomaine=dom;
      const rh=document.createElement('div');rh.className='rh';
      const label=dom.split(' ').map(w=>w[0]+w.slice(1).toLowerCase()).join(' ');
      rh.innerHTML=`<h3>${label}</h3><div class="rl"></div>`;
      el.appendChild(rh);
    }
    const sh=document.createElement('div');sh.className='sh2';
    const catLabel=cat.split(' ').map(w=>w[0]+(w.slice(1).toLowerCase())).join(' ');
    sh.innerHTML=`<h4>${catLabel}</h4><div class="sl2"></div><span class="sc2">${gd[k].length}</span>`;
    el.appendChild(sh);
    gd[k].forEach((s,i)=>{const c=mkSpiritCard(s);c.style.animationDelay=(i*.014)+'s';el.appendChild(c);});
  });
}

