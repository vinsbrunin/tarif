    if(F.region||F.domaine){
      const gd={},od=[];
      gr[region].forEach(w=>{const k=w.domaine||'';if(!gd[k]){gd[k]=[];od.push(k);}gd[k].push(w);});
      od.forEach(dom=>{
        const dh=document.createElement('div');dh.className='dh2';
        dh.innerHTML=`<h4>${dom||'—'}</h4><div class="dl"></div><span class="dc">${gd[dom].length}</span>`;
        el.appendChild(dh);
        gd[dom].forEach((w,i)=>{const c=mkCard(w);c.style.animationDelay=(i*.014)+'s';el.appendChild(c);});
      });
    } else {
      gr[region].forEach((w,i)=>{const c=mkCard(w);c.style.animationDelay=(i*.014)+'s';el.appendChild(c);});
    }
  });
}

function mkCard(w){
  const card=document.createElement('div');
  card.className='wc'+(openRef===w.ref?' open':'')+(selection.has(w.ref)?' sel':'');
  const p=getPrice(w);
  const cc=colorCls(w.couleur);
  const showDom=w.domaine&&w.domaine!==w.nom;
  card.innerHTML=`
    <div class="wm" style="position:relative">
      <div class="cb2 ${cc}"></div>
      <div class="wb">
        <div class="wt">
          <div>
            <div class="wn"><span class="wdot ${cc}"></span>${w.nom}</div>
            ${showDom?`<div class="wd">${w.domaine}</div>`:''}
          </div>
          <div style="display:flex;align-items:center">
            <div class="wpc">
              <div class="wpv">${fmt(p)}</div>
              <div class="wpt">${TL[tarif]}</div>
            </div>
            <div class="wchk" onclick="toggleSel(event,'${w.ref}')">
              ${selection.has(w.ref)?`<svg width="11" height="9" viewBox="0 0 11 9" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4l3 3 6-6"/></svg>`:''}
            </div>
          </div>
        </div>
        <div class="wmt">
          ${w.appellation?`<span class="bdg ba">${w.appellation}</span>`:''}
          ${w.millesime?`<span class="bdg bm">${w.millesime}</span>`:''}
          <span class="bdg bc">${fmtCL(w.cl)}</span>
          ${w.bio&&w.bio!=='nan'?`<span class="bdg bb">🌿 ${w.bio}</span>`:''}
        </div>
      </div>
    </div>
    <div class="ei"><svg width="14" height="8" viewBox="0 0 14 8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M1 1l6 6 6-6"/></svg></div>
    <div class="wd2">${mkDetail(w)}</div>`;
  card.addEventListener('click',e=>{
    if(e.target.closest('.wchk'))return;
    const was=card.classList.contains('open');
    document.querySelectorAll('.wc.open').forEach(c=>c.classList.remove('open'));
    openRef=null;
    if(!was){card.classList.add('open');openRef=w.ref;setTimeout(()=>card.scrollIntoView({behavior:'smooth',block:'nearest'}),80);}
  });
  return card;
}

function ti(lbl,val,hl){return`<div class="ti${hl?' hl':''}""><div class="til">${lbl}</div><div class="tiv">${fmt(val)}</div></div>`}

function mkDetail(w){
  const bel=w.belgique||{},fra=w.france||{};
  const t=tarif;
  function grid(d,isMkt){
    return`<div class="tg">
      ${ti('Part. HTVA',d.particulier_htva,t==='particulier_htva'&&isMkt)}
      ${ti('Part. TTC', d.particulier_ttc, t==='particulier_ttc'&&isMkt)}
      ${ti('Horeca HTVA',d.horeca,         t==='horeca'&&isMkt)}
      ${ti('Gros 1 HTVA',d.gros1,          t==='gros1'&&isMkt)}
      ${ti('Gros 2 HTVA',d.gros2,          t==='gros2'&&isMkt)}
    </div>`;}
  const hBel=Object.values(bel).some(v=>v!==null);
  const hFra=Object.values(fra).some(v=>v!==null);
  let html='';
  if(market==='belgique'&&hBel)html+=`<div class="ds"><div class="dh">🇧🇪 Belgique</div>${grid(bel,true)}</div>`;
  if(market==='france'&&hFra)html+=`<div class="ds"><div class="dh">🇫🇷 France</div>${grid(fra,true)}</div>`;
  if(w.cepages||w.description)html+=`<div class="ds"><div class="dh">Dégustation</div>${w.cepages?`<div class="wcep">🍇 ${w.cepages}</div>`:''}<div class="wdesc">${w.description||''}</div></div>`;
  html+=`<div class="wref">Réf. ${w.ref}</div>`;
  return html;
}

// ─ CONTROLS ─
function setMarket(m){market=m;document.querySelectorAll('.mbt').forEach(b=>b.classList.toggle('on',b.dataset.m===m));render();}
function setTarif(t){tarif=t;document.querySelectorAll('.tc').forEach(b=>b.classList.toggle('on',b.dataset.t===t));render();}

function setFilter(type,val){
  F[type]=val;
  if(type==='region'){F.domaine='';updateDomDrop(val);}
  if(type==='millesime'){const ms=document.getElementById('milSel');ms.classList.toggle('on',!!val);}
  document.querySelectorAll(`[data-ft="${type}"]`).forEach(b=>b.classList.toggle('on',b.dataset.fv===val));
  updATags();render();
}

function updateDomDrop(region){
  const sel=document.getElementById('domSel');
  const prev=sel.value;
  const RL_FR={BORDEAUX:'Bordeaux',BOURGOGNE:'Bourgogne',ALSACE:'Alsace',JURA:'Jura',
    'VAL DE LOIRE':'Val de Loire','SUD-OUEST':'Sud-Ouest',BEAUJOLAIS:'Beaujolais',
    SAVOIE:'Savoie','VALLEE DU RHONE NORD':'Rhône Nord','VALLEE DU RHONE SUD':'Rhône Sud',
    LANGUEDOC:'Languedoc',ROUSSILLON:'Roussillon',PROVENCE:'Provence',
    CHAMPAGNE:'Champagne',CREMANT:'Crémant',BULLES:'Bulles',
    ESPAGNE:'Espagne',CAVA:'Cava',ITALIE:'Italie',PROSECCO:'Prosecco',
    PORTUGAL:'Portugal',CORSE:'Corse',BELGIQUE:'Belgique',
    ARMENIE:'Arménie',CHILI:'Chili',ARGENTINE:'Argentine',AUTRICHE:'Autriche',
    GRECE:'Grèce','NOUVELLE ZELANDE':'Nouvelle-Zélande',MAROC:'Maroc',LIBAN:'Liban'};
  let html='<option value="">— Tous les domaines —</option>';
  const regions=region?[region]:Object.keys(RD);
  regions.forEach(r=>{
    const doms=RD[r]||[];
    if(!doms.length)return;
    const label=RL_FR[r]||r;
    html+=`<optgroup label="— ${label} —">`;
    doms.forEach(d=>{html+=`<option value="${d}">${d}</option>`;});
    html+='</optgroup>';
  });
  sel.innerHTML=html;
  sel.value=prev&&sel.querySelector(`option[value="${prev}"]`)?prev:'';
}

function updATags(){
  const el=document.getElementById('atags'),tags=[];
  if(F.region)tags.push({l:RL[F.region]||F.region,t:'region'});
  if(F.domaine)tags.push({l:F.domaine,t:'domaine'});
  if(F.couleur)tags.push({l:F.couleur,t:'couleur'});
  if(F.format){const fl={'0.375':'37,5cl','0.75':'75cl','1.5':'Magnum','BIG':'Grand format'};tags.push({l:fl[F.format]||F.format,t:'format'});}
  if(F.millesime)tags.push({l:'📅 '+F.millesime,t:'millesime'});
  if(filterBio)tags.push({l:'🌿 Bio',t:'bio'});
  const priceActive=priceRangeMin>0||priceRangeMax<9999;
  if(priceActive){const btn=document.querySelector('.prb.on');tags.push({l:btn?btn.textContent:'Budget',t:'price'});}
  el.classList.toggle('show',tags.length>0);
  el.innerHTML=tags.map(t=>`<span class="atag">${t.l}<button onclick="removeFilter('${t.t}')">×</button></span>`).join('')+(tags.length>1?`<button class="rst-btn" onclick="resetAll()">Tout effacer</button>`:'');
}

function removeFilter(type){
  if(type==='search'){search='';document.getElementById('si').value='';document.getElementById('sx').classList.remove('show');}
  else if(type==='bio'){filterBio=false;document.getElementById('bioBtn').classList.remove('on');}
  else if(type==='price'){resetPriceRange();}
  else{F[type]='';document.querySelectorAll(`[data-ft="${type}"]`).forEach(b=>b.classList.toggle('on',b.dataset.fv===''));if(type==='region'){F.domaine='';updateDomDrop('');}if(type==='millesime'){const ms=document.getElementById('milSel');ms.value='';ms.classList.remove('on');}}
  updATags();render();
}

function resetAll(){
  search='';F={region:'',domaine:'',couleur:'',format:'',millesime:''};filterBio=false;document.getElementById('milSel').value='';document.getElementById('milSel').classList.remove('on');
  resetPriceRange();
  document.getElementById('si').value='';document.getElementById('sx').classList.remove('show');
  document.getElementById('bioBtn').classList.remove('on');
  updateDomDrop('');
  document.querySelectorAll('[data-ft]').forEach(b=>b.classList.toggle('on',b.dataset.fv===''));
  updATags();render();
}

function clearSearch(){search='';document.getElementById('si').value='';document.getElementById('sx').classList.remove('show');updATags();render();}

document.getElementById('si').addEventListener('input',function(){
  search=this.value.trim();
  document.getElementById('sx').classList.toggle('show',search.length>0);
  updATags();render();
});

function toggleBio(){
  filterBio=!filterBio;
  document.getElementById('bioBtn').classList.toggle('on',filterBio);
  updATags();render();
}

function toggleSel(e,ref,isSpirit){
  if(e&&e.stopPropagation)e.stopPropagation();
  let item;
  if(isSpirit){
    const sref=ref.replace(/^S/,'');
    item=SPIRITS.find(x=>x.ref===sref);
    if(!item)return;
    item={...item,_isSpirit:true,_key:ref};
  } else {
    item=WINES.find(x=>x.ref===ref);
    if(!item)return;
  }
  if(selection.has(ref))selection.delete(ref);
  else selection.set(ref,item);
  updateDevisBar();
  render();
}

function updateDevisBar(){
  const n=selection.size;
  document.getElementById('devisCount').textContent=n;
  document.getElementById('devisBar').classList.toggle('show',n>0);
}

function clearSelection(){
  selection.clear();
  updateDevisBar();
  render();
}

function copyDevis(){
  const mktLabel=market==='belgique'?'🇧🇪 Belgique':'🇫🇷 France';
  const tarifLabel=TL[tarif];
  let lines=[`*Brunin-Guillier — Tarif Mars 2026*`,`${mktLabel} · ${tarifLabel}`,``];
  let lastDom='';
  const items=[...selection.values()].sort((a,b)=>{
    const aSpirit=!!a._isSpirit, bSpirit=!!b._isSpirit;
    if(aSpirit!==bSpirit)return aSpirit?1:-1;
    const aKey=a._isSpirit?a.maison:a.domaine;
    const bKey=b._isSpirit?b.maison:b.domaine;
    if(aKey!==bKey)return aKey.localeCompare(bKey,'fr');
    return a.nom.localeCompare(b.nom,'fr');
  });
  items.forEach(item=>{
    const grpName = item._isSpirit ? item.maison : item.domaine;
    if(grpName&&grpName!==lastDom){
      if(lastDom)lines.push('');
      lines.push(`*${grpName}*`);
      lastDom=grpName;
    }
    const p=getPrice(item);
    const price=p?fmt(p):'—';
    if(item._isSpirit){
      lines.push(`• ${item.nom} — ${item.format||''} — ${price}`);
    } else {
      const mil=item.millesime?` ${item.millesime}`:'';
      const cl=item.cl&&item.cl!=='0.75'?` (${fmtCL(item.cl)})`:'';
      lines.push(`• ${item.nom}${mil}${cl} — ${item.appellation||item.region} — ${price}`);
    }
  });
  lines.push('');
  lines.push(`_${selection.size} référence(s) — Réf. disponibles sur demande_`);
  const text=lines.join('\n');
  navigator.clipboard.writeText(text).then(()=>{
    const ok=document.getElementById('devisOk');
    ok.style.display='block';
    setTimeout(()=>{ok.style.display='none';},2500);
  }).catch(()=>{
    // Fallback
    const ta=document.createElement('textarea');
    ta.value=text;ta.style.position='fixed';ta.style.opacity='0';
    document.body.appendChild(ta);ta.select();document.execCommand('copy');
    document.body.removeChild(ta);
    const ok=document.getElementById('devisOk');
    ok.style.display='block';
    setTimeout(()=>{ok.style.display='none';},2500);
  });
}

// ─ INIT ─
updateDomDrop('');
render();
</script>


